# ProMoAgentAI Configuration
# Copy this file to .env and fill in your values

# ======================
# Model Selection
# Options: sonnet-4.5, gpt-5.2, gemini-3
# As per paper Table 2 - defaults to sonnet-4.5
# ======================
MODEL_NAME="sonnet-4.5"

# ======================
# LLM API Keys
# Provide the key for your selected model
# ======================

# For Claude Sonnet 4.5 (best quality: 0.95)
ANTHROPIC_API_KEY="your_anthropic_api_key_here"

# For GPT-5.2 (using GPT-4o) (quality: 0.94)
OPENAI_API_KEY="your_openai_api_key_here"

# For Gemini 3 (using Gemini 1.5 Pro) (quality: 0.97)
GOOGLE_API_KEY="your_google_api_key_here"

# ======================
# Camunda BPM Configuration
# ======================
CAMUNDA_URL="http://localhost:8080"
CAMUNDA_USERNAME="demo"
CAMUNDA_PASSWORD="demo"

# ======================
# External Viewer
# ======================
BPMN_IO_VIEWER_URL="https://demo.bpmn.io"

# ======================
# Batch Processing
# ======================
BATCH_OUTPUT_DIR="./batch_output"
BATCH_MAX_CONCURRENT="1"

# ======================
# Generation Settings
# ======================
MAX_FIX_ITERATIONS="5"
MAX_CAMUNDA_ATTEMPTS="3"
GENERATION_TIMEOUT="180"

# ======================
# Feature Flags
# ======================
ENABLE_CAMUNDA_DEPLOYMENT="true"
ENABLE_BATCH_PROCESSING="true"
ENABLE_EXTERNAL_VIEWER="true"
ENABLE_ARABIC_SUPPORT="true"
