        <di:waypoint x="840" y="100"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_6_di" bpmnElement="Flow_6">
        <di:waypoint x="940" y="100"/>
        <di:waypoint x="965" y="100"/>
        <di:waypoint x="965" y="700"/>
        <di:waypoint x="990" y="700"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_7_di" bpmnElement="Flow_7">
        <di:waypoint x="1090" y="700"/>
        <di:waypoint x="1115" y="700"/>
        <di:waypoint x="1115" y="580"/>
        <di:waypoint x="1140" y="580"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_8_di" bpmnElement="Flow_8">
        <di:waypoint x="1240" y="580"/>
