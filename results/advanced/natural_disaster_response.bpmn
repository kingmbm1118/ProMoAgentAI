    <bpmn:sequenceFlow id="Flow_10" sourceRef="Task_5" targetRef="Gateway_2"/>
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Task_6" targetRef="Gateway_2"/>
    <bpmn:sequenceFlow id="Flow_12" sourceRef="Gateway_2" targetRef="Task_7"/>
    <bpmn:sequenceFlow id="Flow_13" sourceRef="Task_7" targetRef="Task_8"/>
    <bpmn:sequenceFlow id="Flow_14" sourceRef="Task_8" targetRef="Task_9"/>
    <bpmn:sequenceFlow id="Flow_15" sourceRef="Task_9" targetRef="Task_10"/>
    <bpmn:sequenceFlow id="Flow_16" sourceRef="Task_10" targetRef="End_1"/>

  </bpmn:process>

