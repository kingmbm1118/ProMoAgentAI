<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_security"
                  targetNamespace="http://example.com/telecom"
                  exporter="ProMoAgentAI"
                  exporterVersion="1.0">

  <bpmn:process id="Process_SecurityUpgrade" name="تنفيذ مشروع تحديث البنية الأمنية" isExecutable="true">

    <bpmn:startEvent id="Start_1" name="موافقة الإدارة على التحديث">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="Task_1" name="تشكيل فريق المشروع">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_2" name="تقييم الوضع الحالي وتحديد الثغرات">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_3" name="تحديد الأولويات وإعداد خطة تنفيذ متعددة المراحل">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_4" name="التعاقد على الحلول الأمنية">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:subProcess id="SubProcess_1" name="تنصيب وضبط الأنظمة الأمنية">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>

      <bpmn:startEvent id="SubStart_1">
        <bpmn:outgoing>SubFlow_1</bpmn:outgoing>
      </bpmn:startEvent>

      <bpmn:task id="SubTask_1" name="تنصيب جدران نارية متقدمة">
        <bpmn:incoming>SubFlow_1</bpmn:incoming>
        <bpmn:outgoing>SubFlow_2</bpmn:outgoing>
      </bpmn:task>

      <bpmn:task id="SubTask_2" name="تنصيب نظام كشف اختراق">
        <bpmn:incoming>SubFlow_2</bpmn:incoming>
        <bpmn:outgoing>SubFlow_3</bpmn:outgoing>
      </bpmn:task>

      <bpmn:task id="SubTask_3" name="تنصيب نظام إدارة هويات">
        <bpmn:incoming>SubFlow_3</bpmn:incoming>
        <bpmn:outgoing>SubFlow_4</bpmn:outgoing>
      </bpmn:task>

      <bpmn:task id="SubTask_4" name="تنصيب نظام منع تسريب البيانات">
        <bpmn:incoming>SubFlow_4</bpmn:incoming>
        <bpmn:outgoing>SubFlow_5</bpmn:outgoing>
      </bpmn:task>

      <bpmn:endEvent id="SubEnd_1">
        <bpmn:incoming>SubFlow_5</bpmn:incoming>
      </bpmn:endEvent>

      <bpmn:sequenceFlow id="SubFlow_1" sourceRef="SubStart_1" targetRef="SubTask_1"/>
      <bpmn:sequenceFlow id="SubFlow_2" sourceRef="SubTask_1" targetRef="SubTask_2"/>
      <bpmn:sequenceFlow id="SubFlow_3" sourceRef="SubTask_2" targetRef="SubTask_3"/>
      <bpmn:sequenceFlow id="SubFlow_4" sourceRef="SubTask_3" targetRef="SubTask_4"/>
      <bpmn:sequenceFlow id="SubFlow_5" sourceRef="SubTask_4" targetRef="SubEnd_1"/>
    </bpmn:subProcess>

    <bpmn:userTask id="Task_5" name="إجراء اختبارات اختراق">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_6" name="تدريب فريق الأمن على الأدوات الجديدة">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_7" name="تحديث السياسات والإجراءات الأمنية">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_8" name="تدريب الموظفين على الوعي الأمني">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:serviceTask id="Task_9" name="بدء المراقبة المحسنة على مدار الساعة">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="End_1" name="اكتمال التحديث الأمني">
      <bpmn:incoming>Flow_11</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="Start_1" targetRef="Task_1"/>
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_1" targetRef="Task_2"/>
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_2" targetRef="Task_3"/>
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_3" targetRef="Task_4"/>
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_4" targetRef="SubProcess_1"/>
    <bpmn:sequenceFlow id="Flow_6" sourceRef="SubProcess_1" targetRef="Task_5"/>
    <bpmn:sequenceFlow id="Flow_7" sourceRef="Task_5" targetRef="Task_6"/>
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Task_6" targetRef="Task_7"/>
    <bpmn:sequenceFlow id="Flow_9" sourceRef="Task_7" targetRef="Task_8"/>
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Task_8" targetRef="Task_9"/>
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Task_9" targetRef="End_1"/>

  </bpmn:process>

