<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_crm"
                  targetNamespace="http://example.com/telecom"
                  exporter="ProMoAgentAI"
                  exporterVersion="1.0">

  <bpmn:process id="Process_CRM" name="تنفيذ مشروع نظام إدارة علاقات العملاء" isExecutable="true">

    <bpmn:startEvent id="Start_1" name="موافقة الإدارة على المشروع">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="Task_1" name="تشكيل فريق المشروع متعدد التخصصات">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_2" name="جمع متطلبات المستخدمين">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_3" name="تقييم الأنظمة المتاحة واختيار الأنسب">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_4" name="التفاوض مع المورد وتوقيع العقد">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:parallelGateway id="Gateway_1" name="بدء العمل المتوازي">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:userTask id="Task_5" name="تجهيز البنية التحتية وتنصيب النظام">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_6" name="ترحيل بيانات العملاء وتنظيفها">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_7" name="ربط النظام مع الأنظمة الأخرى">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:parallelGateway id="Gateway_2" name="التقاء">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:userTask id="Task_8" name="ضبط الإعدادات وبناء التقارير المخصصة">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_9" name="إجراء اختبارات شاملة وإصلاح المشاكل">
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_10" name="تدريب الموظفين على النظام الجديد">
      <bpmn:incoming>Flow_14</bpmn:incoming>
      <bpmn:outgoing>Flow_15</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_11" name="التشغيل التدريجي ومتابعة التبني">
      <bpmn:incoming>Flow_15</bpmn:incoming>
      <bpmn:outgoing>Flow_16</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_12" name="معالجة مقاومة التغيير والتوسع">
      <bpmn:incoming>Flow_16</bpmn:incoming>
      <bpmn:outgoing>Flow_17</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:endEvent id="End_1" name="اكتمال المشروع">
      <bpmn:incoming>Flow_17</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="Start_1" targetRef="Task_1"/>
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_1" targetRef="Task_2"/>
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_2" targetRef="Task_3"/>
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_3" targetRef="Task_4"/>
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_4" targetRef="Gateway_1"/>
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Gateway_1" targetRef="Task_5"/>
    <bpmn:sequenceFlow id="Flow_7" sourceRef="Gateway_1" targetRef="Task_6"/>
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Gateway_1" targetRef="Task_7"/>
    <bpmn:sequenceFlow id="Flow_9" sourceRef="Task_5" targetRef="Gateway_2"/>
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Task_6" targetRef="Gateway_2"/>
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Task_7" targetRef="Gateway_2"/>
    <bpmn:sequenceFlow id="Flow_12" sourceRef="Gateway_2" targetRef="Task_8"/>
    <bpmn:sequenceFlow id="Flow_13" sourceRef="Task_8" targetRef="Task_9"/>
    <bpmn:sequenceFlow id="Flow_14" sourceRef="Task_9" targetRef="Task_10"/>
    <bpmn:sequenceFlow id="Flow_15" sourceRef="Task_10" targetRef="Task_11"/>
    <bpmn:sequenceFlow id="Flow_16" sourceRef="Task_11" targetRef="Task_12"/>
    <bpmn:sequenceFlow id="Flow_17" sourceRef="Task_12" targetRef="End_1"/>

  </bpmn:process>

