                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_sports_event"
                  targetNamespace="http://example.com/telecom"
                  exporter="ProMoAgentAI"
                  exporterVersion="1.0">

  <bpmn:process id="Process_SportsEventCoverage" name="تنفيذ مشروع تغطية حدث رياضي كبير" isExecutable="true">

    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_PM" name="مدير المشاريع">
        <bpmn:flowNodeRef>Start_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_9</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_1</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Network" name="فريق الشبكة">
        <bpmn:flowNodeRef>Task_2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_5</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_7</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Procurement" name="المشتريات">
        <bpmn:flowNodeRef>Task_3</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Marketing" name="التسويق والمبيعات">
        <bpmn:flowNodeRef>Task_4</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_6</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_NOC" name="مركز العمليات">
        <bpmn:flowNodeRef>Task_8</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="Start_1" name="الحصول على عقد تغطية البطولة">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="Task_1" name="تشكيل فريق عمل والاجتماع مع اللجنة المنظمة">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:parallelGateway id="Gateway_1" name="بدء التحضير المتوازي">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:userTask id="Task_2" name="تصميم خطة التغطية المؤقتة">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_3" name="طلب المعدات والتعاقد مع مقاولين">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_4" name="تصميم الحملة الدعائية وعروض الزوار">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:parallelGateway id="Gateway_2" name="اكتمال التحضير">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:userTask id="Task_5" name="تركيب المعدات واختبار التغطية">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_6" name="توفير شرائح خاصة للزوار">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_7" name="مراقبة الشبكة ومعالجة المشاكل خلال الحدث">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_8" name="تجهيز غرفة مراقبة مخصصة للحدث">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_9" name="تفكيك المعدات وإعداد تقرير الإنجاز">
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:endEvent id="End_1" name="اكتمال مشروع تغطية الحدث">
      <bpmn:incoming>Flow_14</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="Start_1" targetRef="Task_1"/>
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_1" targetRef="Gateway_1"/>
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Gateway_1" targetRef="Task_2"/>
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Gateway_1" targetRef="Task_3"/>
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Gateway_1" targetRef="Task_4"/>
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Task_2" targetRef="Gateway_2"/>
    <bpmn:sequenceFlow id="Flow_7" sourceRef="Task_3" targetRef="Gateway_2"/>
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Task_4" targetRef="Gateway_2"/>
    <bpmn:sequenceFlow id="Flow_9" sourceRef="Gateway_2" targetRef="Task_5"/>
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Task_5" targetRef="Task_6"/>
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Task_6" targetRef="Task_7"/>
    <bpmn:sequenceFlow id="Flow_12" sourceRef="Task_7" targetRef="Task_8"/>
    <bpmn:sequenceFlow id="Flow_13" sourceRef="Task_8" targetRef="Task_9"/>
    <bpmn:sequenceFlow id="Flow_14" sourceRef="Task_9" targetRef="End_1"/>

  </bpmn:process>

