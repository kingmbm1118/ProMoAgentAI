<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_upgrade_internet"
                  targetNamespace="http://example.com/telecom"
                  exporter="ProMoAgentAI"
                  exporterVersion="1.0">

  <bpmn:process id="Process_UpgradeInternet" name="معالجة طلب ترقية سرعة الإنترنت" isExecutable="true">

    <bpmn:startEvent id="Start_1" name="طلب ترقية السرعة">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="Task_1" name="التحقق من الباقات المتاحة للمنطقة">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:serviceTask id="Task_2" name="التحقق من إمكانية البنية التحتية">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="Gateway_1" name="هل الترقية ممكنة؟">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="Task_3" name="عرض الخيارات والأسعار للعميل">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_4" name="موافقة العميل واختيار الباقة">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_5" name="تسجيل طلب الترقية">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:serviceTask id="Task_6" name="تعديل الإعدادات ورفع السرعة">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="Gateway_2" name="هل تحتاج تغيير راوتر؟">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="Task_7" name="جدولة زيارة فني">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="Gateway_3" name="نقطة التقاء">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="End_1" name="تم الترقية">
      <bpmn:incoming>Flow_13</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:userTask id="Task_8" name="إبلاغ العميل بعدم توفر الترقية">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:endEvent id="End_2" name="الترقية غير متاحة">
      <bpmn:incoming>Flow_14</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="Start_1" targetRef="Task_1"/>
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_1" targetRef="Task_2"/>
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_2" targetRef="Gateway_1"/>
    <bpmn:sequenceFlow id="Flow_4" name="نعم" sourceRef="Gateway_1" targetRef="Task_3"/>
    <bpmn:sequenceFlow id="Flow_5" name="لا" sourceRef="Gateway_1" targetRef="Task_8"/>
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Task_3" targetRef="Task_4"/>
    <bpmn:sequenceFlow id="Flow_7" sourceRef="Task_4" targetRef="Task_5"/>
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Task_5" targetRef="Task_6"/>
    <bpmn:sequenceFlow id="Flow_9" sourceRef="Task_6" targetRef="Gateway_2"/>
    <bpmn:sequenceFlow id="Flow_10" name="نعم" sourceRef="Gateway_2" targetRef="Task_7"/>
    <bpmn:sequenceFlow id="Flow_11" name="لا" sourceRef="Gateway_2" targetRef="Gateway_3"/>
    <bpmn:sequenceFlow id="Flow_12" sourceRef="Task_7" targetRef="Gateway_3"/>
    <bpmn:sequenceFlow id="Flow_13" sourceRef="Gateway_3" targetRef="End_1"/>
    <bpmn:sequenceFlow id="Flow_14" sourceRef="Task_8" targetRef="End_2"/>

  </bpmn:process>

